# Vorlage für .env.local (lokal) und .env.production (Server).
# Echte Werte NIE committen — beide Dateien sind in .gitignore.

# === Strato-SMTP (Postfach restaurant@mijorent.de) ===
# Quelle der Zugangsdaten: lokal in /secure/email.txt (nicht im Repo)
EMAIL_HOST=smtp.strato.de
EMAIL_PORT=465
EMAIL_USER=restaurant@mijorent.de
EMAIL_PASS=

# Empfänger aller Formularzusendungen (kann identisch zu EMAIL_USER sein)
EMAIL_TO=restaurant@mijorent.de

# Absender-Anzeige (was im Postfach als „Von" erscheint).
# Bei Strato MUSS dieser identisch zu EMAIL_USER sein, sonst lehnt der
# Server ab. Daher nicht abweichend setzen.
EMAIL_FROM_NAME=Restaurant Alt-Karow Website

# === Admin-Login (Reservierungs-Dashboard) ===
# Quelle: /secure/admin.txt (nicht im Repo)
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=

# Zufalls-Hex (z. B. via `openssl rand -hex 32`). Bei Wechsel werden
# alle bestehenden Admin-Sessions ungültig.
ADMIN_SESSION_SECRET=

# === Datenbank ===
# Lokal:    ./data/restaurantaltkarow.db
# Auf VPS:  /var/www/restaurantaltkarow/data/restaurantaltkarow.db
DATABASE_PATH=./data/restaurantaltkarow.db
