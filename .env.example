# Beispiel-Variablen für lokale Entwicklung und Production.
# Echte Werte in .env.local (dev) bzw. .env.production (server) eintragen — NIE committen.

# Beispiel — wird je nach späteren Features ergänzt:
# EMAIL_HOST=smtp.ionos.de
# EMAIL_PORT=465
# EMAIL_USER=kontakt@restaurant-alt-karow.de
# EMAIL_PASS=
# EMAIL_TO=kontakt@restaurant-alt-karow.de
